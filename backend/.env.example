# --- Локальная разработка (по умолчанию) — SQLite, файл рядом с рабочей директорией ---
DATABASE_URL=sqlite:///./matchme.db

# --- PostgreSQL (Neon, Render и т.д.) — значение только в .env на сервере / в секретах CI, не в git ---
# Подходит и вид из Neon «Connection string» (postgresql://…), приложение само добавит +psycopg2.
# Обязательно sslmode=require. Если psycopg2 на Windows ругается на channel_binding — уберите
# channel_binding из строки или поставьте channel_binding=disable в параметрах запроса.
# Пример формы (подставьте свои хост/пользователя/пароль из Neon):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require
# Для многих коротких соединений (локальная разработка, serverless-воркеры) в Neon берите
# строку с хостом **-pooler** (раздел Connect → Pooling), чтобы не исчерпать лимиты соединений.

JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
# На проде — URL фронта на Render (или список через запятую)
# Несколько origin через запятую; добавьте порт Next, если открываете :3300 и т.д.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3300,http://127.0.0.1:3300

# --- Групповые комнаты (опционально; иначе значения из app/config.py) ---
# GROUP_COHORT_MEAN_DIVERGENCE_MAX=0.28
# GROUP_COHORT_AXIS_DIVERGENCE_MAX=0.42
# GROUP_MIN_MEMBERS=3
# GROUP_MAX_MEMBERS=12
