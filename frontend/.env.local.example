# Рекомендуется: не задавать URL — фронт ходит на /api, Next проксирует на BACKEND_URL (по умолчанию http://127.0.0.1:8000).
# NEXT_PUBLIC_API_URL=

# Если бэкенд на другом хосте/порту без прокси:
# NEXT_PUBLIC_API_URL=https://api.example.com

# Для next dev: куда проксировать /api (редко нужно менять)
# BACKEND_URL=http://127.0.0.1:8000

# Задержки: при Neon первый запрос к API может быть долгим из‑за сети; первый заход на страницу
# в `next dev` ещё компилируется — для оценки скорости см. `npm run build` + `npm run start` и README.md.
